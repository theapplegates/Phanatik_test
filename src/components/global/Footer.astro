---
// Assets
import Logo from "@/components/assets/Logo.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "../fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Get all posts
import { getCollection } from "astro:content";
const allPosts = await getCollection("posts");
allPosts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime(); // Convert to timestamp
  const dateB = new Date(b.data.pubDate).getTime(); // Convert to timestamp
  return dateB - dateA; // Compare timestamps
});
// Tags
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())];
// Array
const sections = [
  {
    title: "Company",
    links: [
      { name: "About", url: "/about" },
      { name: "Carriers", url: "/jobs" },
      { name: "Authors", url: "/authors" },
      { name: "Advertise", url: "/pricing/advertise" },
      { name: "Contact", url: "/contact" },
    ],
  },
  {
    title: "Categories",
    links: [
      ...tags.map((tag) => ({
        name: tag.replace(/-/g, " "), // Format the tag by replacing hyphens with spaces
        url: `/blog/tags/${tag}`,
      })),
    ],
  },
  {
    title: "Company",
    links: [
      { name: "Twitter", url: "#_" },
      { name: "Linkedin", url: "#_" },
      { name: "Youtube", url: "#_" },
      { name: "Facebook", url: "#_" },
      { name: "Instagram", url: "#_" },
    ],
  },
];
---

<footer class="bg-base-950">
  <Wrapper variant="standard" class="py-12">
    <div class="grid grid-cols-1 lg:grid-cols-6 gap-8 lg:gap-12">
      <div class="lg:col-span-2 order-last">
        <Text
          tag="h3"
          variant="textBase"
          class="text-white font-display font-medium"
          >Subscribe to <Logo /></Text
        >
        <Text tag="p" variant="textXS" class="text-base-400 mt-2">
          Stay in the loop with Phanatik! We bring you the latest buzz in
          business, tech, sports, and more—because who has time for FOMO? Get it
          straight to your inbox, faster than you can say ‘breaking news!
        </Text>
        <form class="flex w-full items-end md:w-auto mt-4 gap-2">
          <div class="flex flex-col w-full">
            <label for="email" class="text-xs text-base-400"
              >Email address</label
            >
            <div class="mt-1">
              <input
                type="email"
                id="email"
                required
                aria-label="Email address"
                autocomplete="email"
                class="block w-full h-9 px-4 py-2 text-sm text-white border border-transparent rounded-lg appearance-none duration-300 bg-white/10 placeholder-base-400 focus:bg-white/5 focus:outline-none focus:ring-white/10 focus:ring-2 focus:ring-offset-base-950"
              />
            </div>
          </div>
          <Button size="sm" variant="muted" type="submit" class="flex"
            >Subscribe</Button
          >
        </form>
        <Text tag="p" variant="textXS" class="mt-1 text-base-400">
          We won't spam you on weekdays, only on weekends.
        </Text>
      </div>
      <div
        class="grid gap-4 lg:gap-8 grid-cols-2 lg:grid-cols-4 lg:col-span-4 gap-y-12"
      >
        {
          sections.map((section) => (
            <div>
              <Text
                tag="h3"
                variant="textXS"
                class="flex gap-x-2 text-white justify-between uppercase font-medium"
              >
                {section.title}
              </Text>
              <ul
                role="list"
                class="mt-2 relative before:absolute after:absolute before:bg-base-950 after:bg-base-950/10 before:top-0 before:left-0 before:h-px before:w-6 after:top-0 after:right-0 after:left-8 after:h-px pt-4"
              >
                {section.links.map((link) => (
                  <li>
                    <Text
                      tag="a"
                      variant="textXS"
                      class="text-base-400 hover:underline capitalize"
                      href={link.url}
                    >
                      {link.name}
                    </Text>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
    <div
      class="mt-42 lg:mt-62 relative before:absolute after:absolute before:bg-white after:bg-white/10 before:top-0 before:left-0 before:h-px before:w-6 after:top-0 after:right-0 after:left-8 after:h-px pt-4"
    >
      <Text tag="p" variant="textXS" class="text-base-600">
        © Copyright Lexington Themes {new Date().getFullYear()}
      </Text>
    </div>
  </Wrapper>
</footer>
