{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "bio": {
      "type": "string"
    },
    "image": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        }
      },
      "required": [
        "url",
        "alt"
      ]
    },
    "socials": {
      "type": "object",
      "properties": {
        "twitter": {
          "type": "string"
        },
        "website": {
          "type": "string"
        },
        "linkedin": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "image"
  ]
}